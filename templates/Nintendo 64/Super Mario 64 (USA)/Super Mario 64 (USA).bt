enum <ubyte> Language {    English = 0x0,    French  = 0x1,    German  = 0x2,};
enum <ubyte> Ranking {    Newest          = 0x0,    ModeratelyNew   = 0x1,    ModeratelyOld   = 0x2,    Oldest          = 0x3,};

enum <ubyte> SoundMode {    Stereo  = 0x0,    Mono    = 0x1,    Headset = 0x2,};

typedef struct {    Ranking BobOmbBattlefield :2 <read=RankingToString(this)>;    Ranking WhompsFortress    :2 <read=RankingToString(this)>;    Ranking JollyRogerBay     :2 <read=RankingToString(this)>;    Ranking CoolCoolMountain  :2 <read=RankingToString(this)>;} Group_1_4;typedef struct {    Ranking BigBoosHaunt   :2 <read=RankingToString(this)>;    Ranking HazyMazeCave   :2 <read=RankingToString(this)>;    Ranking LethalLavaLand :2 <read=RankingToString(this)>;    Ranking ShiftingSandLand :2 <read=RankingToString(this)>;} Group_5_8;typedef struct {    Ranking DireDireDocks    :2 <read=RankingToString(this)>;    Ranking SnowmansLand     :2 <read=RankingToString(this)>;    Ranking WetDryWorld      :2 <read=RankingToString(this)>;    Ranking TallTallMountain :2 <read=RankingToString(this)>;} Group_9_12;typedef struct {    Ranking TinyHugeIsland :2 <read=RankingToString(this)>;    Ranking TickTockClock  :2 <read=RankingToString(this)>;    Ranking RainbowRide    :2 <read=RankingToString(this)>;    ubyte unused           :2 <hidden=true>;} Group_13_15;

typedef struct {    /* -------- Mario 1 --------*/    Group_13_15 m1_courses_13_15;    Group_9_12  m1_courses_9_12;    Group_5_8   m1_courses_5_8;    Group_1_4   m1_courses_1_4;    /* -------- Mario 2 -------- */    Group_13_15 m2_courses_13_15;    Group_9_12  m2_courses_9_12;    Group_5_8   m2_courses_5_8;    Group_1_4   m2_courses_1_4;    /* -------- Mario 3 --------*/    Group_13_15 m3_courses_13_15;    Group_9_12  m3_courses_9_12;    Group_5_8   m3_courses_5_8;    Group_1_4   m3_courses_1_4;    /* -------- Mario 4 -------- */    Group_13_15 m4_courses_13_15;    Group_9_12  m4_courses_9_12;    Group_5_8   m4_courses_5_8;    Group_1_4   m4_courses_1_4;} Score <bgcolor=cPurple>;

enum <ubyte> StatusEnum {OK=1,MISSING=0};
enum <ubyte> LevelStatus {NOT_COMPLETED=0, COMPLETED=1};
enum <ubyte> FLAG {False=0, True=1};
enum <ubyte> Course {
    None=0x0,    BobOmbBattlefield = 0x1,    WhompsFortress    = 0x2,    JollyRogerBay     = 0x3,    CoolCoolMountain  = 0x4,    BigBoosHaunt      = 0x5,    HazyMazeCave      = 0x6,    LethalLavaLand    = 0x7,    ShiftingSandLand  = 0x8,    DireDireDocks     = 0x9,    SnowmansLand      = 0xA,    WetDryWorld       = 0xB,    TallTallMountain  = 0xC,    TinyHugeIsland    = 0xD,    TickTockClock     = 0xE,    RainbowRide       = 0xF,};
