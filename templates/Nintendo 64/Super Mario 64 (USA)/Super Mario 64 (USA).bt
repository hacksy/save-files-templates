string SoundModeToString(ubyte v){    switch (v)    {        case Stereo:  return "Stereo";        case Mono:    return "Mono";        case Headset: return "Headset";    }    return Str("Unknown (%d)", v);}
string CourseToString(Course c){    switch (c)    {
        case None: return "---";        case BobOmbBattlefield: return "Bob-omb Battlefield";        case WhompsFortress:    return "Whomp's Fortress";        case JollyRogerBay:     return "Jolly Roger Bay";        case CoolCoolMountain:  return "Cool, Cool Mountain";        case BigBoosHaunt:      return "Big Boo's Haunt";        case HazyMazeCave:      return "Hazy Maze Cave";        case LethalLavaLand:    return "Lethal Lava Land";        case ShiftingSandLand:  return "Shifting Sand Land";        case DireDireDocks:     return "Dire, Dire Docks";        case SnowmansLand:      return "Snowman's Land";        case WetDryWorld:       return "Wet-Dry World";        case TallTallMountain:  return "Tall, Tall Mountain";        case TinyHugeIsland:    return "Tiny-Huge Island";        case TickTockClock:     return "Tick Tock Clock";        case RainbowRide:       return "Rainbow Ride";    }    return Str("Unknown (%d)", c);}



string RankingToString(ubyte r){    switch (r)    {        case Newest:        return "Newest";        case ModeratelyNew: return "Moderately New";        case ModeratelyOld: return "Moderately Old";        case Oldest:        return "Oldest";    }    return Str("Unknown (%d)", r);}

string LanguageToString(ubyte v){    switch (v)    {        case English: return "English";        case French:  return "French";        case German:  return "German";    }    return Str("Unknown (%d)", v);}