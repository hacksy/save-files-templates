#include "helpers/methods.bt"


string ReadBCD24(ubyte raw[3]){    return Str(        "%d%d%d%d%d%d",        (raw[0] >> 4) & 0xF, raw[0] & 0xF,        (raw[1] >> 4) & 0xF, raw[1] & 0xF,        (raw[2] >> 4) & 0xF, raw[2] & 0xF    );}
string ReadBCD8(ubyte b){    local int hi = (b >> 4) & 0xF;    local int lo = b & 0xF;    /* optional: validate BCD */    if (hi > 9 || lo > 9)        return Str("INVALID(%02X)", b);    return Str("%d%d", hi, lo);}


string TreasureA_Label(ubyte v) { return Str("Treasure A: Golden Horn (%d)", v); }string TreasureC_Label(ubyte v) { return Str("Treasure C: Crown (%d)", v); }string TreasureF_Label(ubyte v) { return Str("Treasure F: Lamp (%d)", v); }string TreasureO_Label(ubyte v) { return Str("Treasure O: Diamond Ring (%d)", v); }string TreasureN_Label(ubyte v) { return Str("Treasure N: Whale (%d)", v); }string TreasureH_Label(ubyte v) { return Str("Treasure H: Chalice (%d)", v); }string TreasureI_Label(ubyte v) { return Str("Treasure I: Dagger (%d)", v); }
string TreasureB_Label(ubyte v) { return Str("Treasure B: Harp (%d)", v); }string TreasureD_Label(ubyte v) { return Str("Treasure D: Shield (%d)", v); }string TreasureE_Label(ubyte v) { return Str("Treasure E: Bell (%d)", v); }string TreasureG_Label(ubyte v) { return Str("Treasure G: Crystal Ball (%d)", v); }string TreasureJ_Label(ubyte v) { return Str("Treasure J: Axe (%d)", v); }string TreasureK_Label(ubyte v) { return Str("Treasure K: Football (%d)", v); }string TreasureL_Label(ubyte v) { return Str("Treasure L: Idol (%d)", v); }string TreasureM_Label(ubyte v) { return Str("Treasure M: Golden Glove (%d)", v); }