LittleEndian();
#include "helpers/colors.bt"
#include "helpers/structs.bt"


typedef struct{
    local ubyte header[4] = {0x19,0x64,0x39,0x57};
    Validator value(header);    
} Header;

typedef struct{
    ubyte raw[3] <hidden=true>;       
} Coins <fgcolor=cLtBlue,read=Str("Coins: %s",ReadBCD24(raw))>;

typedef struct{
    ubyte raw <hidden=true>;     
} Hearts <fgcolor=cPink,read=Str("Hearts: %s",ReadBCD8(raw))>;

typedef struct{
    ubyte raw <hidden=true>;    
} Lives <fgcolor=cPink,read=Str("Lives: %s",ReadBCD8(raw))>;

enum <ubyte> PowerUpsEnum{
    Small_Wario =0,Wario=1,Bull_Wario=2,Jet_Wario=3,Dragon_Wario=4
};

typedef struct{
    PowerUpsEnum value <hidden=true>;    
} PowerUps <fgcolor=cAqua,read=EnumToString(value)>;

enum <ubyte> ProgressionEnum{
    Incomplete =0,Complete=1,
};

typedef struct{
    ProgressionEnum value <hidden=true>;    
} Progression <fgcolor=cAqua,read=EnumToString(value)>;
