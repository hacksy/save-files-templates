enum <ubyte> CourseEnum {    Course26 = 0x0,    Course33 = 0x1,    Course15 = 0x2,    Course20 = 0x3,    Course16 = 0x4,    Course10 = 0x5,    Course07 = 0x6,    Course01 = 0x7,    Course17 = 0x8,    Course12 = 0x9,    Course13 = 0xA,    Course29 = 0xB,    Course04 = 0xC,    Course09 = 0xD,    Course03 = 0xE,    Course02 = 0xF,    Course08 = 0x10,    Course11 = 0x11,    Course35 = 0x12,    Course34 = 0x13,    Course30 = 0x14,    Course21 = 0x15,    Course22 = 0x16,    Course01_AfterBoss = 0x17,    Course19 = 0x18,    Course05 = 0x19,    Course36 = 0x1A,    Course24 = 0x1B,    Course25 = 0x1C,    Course32 = 0x1D,    Course27 = 0x1E,    Course28 = 0x1F,    Course18 = 0x20,    Course14 = 0x21,    Course38 = 0x22,    Course39 = 0x23,    Course03_AfterBoss = 0x24,    Course37 = 0x25,    /* 0x26 unused */    Course23 = 0x27,    Course40 = 0x28,    Course06 = 0x29,    Course31 = 0x2A};

typedef struct{
    CourseEnum value <hidden=true>;    
} Course <fgcolor=cAqua,read=EnumToString(value)>;

typedef struct{
    ubyte value;
} SmallChecksum <fgcolor=cAqua>;

